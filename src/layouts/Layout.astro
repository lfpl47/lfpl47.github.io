---
import "../styles/global.css";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { site } from "../config/site";
import type { Locale } from "../i18n/locales";
import { getLocaleFromPathname, withLocale } from "../i18n/routing";
import { t } from "../i18n/ui";

type Props = {
  title?: string;
  description?: string;
  noIndex?: boolean;
  locale?: Locale;
};

const pathname = Astro.url.pathname;
const locale = Astro.props.locale ?? getLocaleFromPathname(pathname);
const title = Astro.props.title ?? site.titles[locale];
const description = Astro.props.description ?? site.descriptions[locale];
const noIndex = Astro.props.noIndex ?? false;

const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : undefined;
const alternateEn = Astro.site ? new URL(withLocale(pathname, "en"), Astro.site).toString() : undefined;
const alternateEs = Astro.site ? new URL(withLocale(pathname, "es"), Astro.site).toString() : undefined;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    {noIndex ? <meta name="robots" content="noindex,nofollow" /> : null}
    {canonical ? <link rel="canonical" href={canonical} /> : null}
    {alternateEn ? <link rel="alternate" href={alternateEn} hreflang="en" /> : null}
    {alternateEs ? <link rel="alternate" href={alternateEs} hreflang="es" /> : null}
    {alternateEn ? <link rel="alternate" href={alternateEn} hreflang="x-default" /> : null}

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonical ? <meta property="og:url" content={canonical} /> : null}
    <meta property="og:type" content="website" />

    <meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
  </head>
  <body
    class="min-h-screen bg-slate-950 text-slate-100 selection:bg-sky-500/30 selection:text-slate-50"
  >
    <a class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-lg focus:bg-slate-900 focus:px-4 focus:py-2 focus:text-slate-50" href="#main">
      {t(locale, "skip_to_content")}
    </a>

    <div class="pointer-events-none fixed inset-0 -z-10">
      <div class="absolute -top-24 left-1/2 h-72 w-[52rem] -translate-x-1/2 rounded-full bg-sky-500/15 blur-3xl" />
      <div class="absolute -bottom-24 right-[-8rem] h-72 w-96 rounded-full bg-fuchsia-500/10 blur-3xl" />
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(56,189,248,0.06),transparent_55%)]" />
    </div>

    <SiteHeader />
    <main id="main">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
