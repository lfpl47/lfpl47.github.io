---
import "../styles/global.css";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import ThemeSwitcher from "../components/ThemeSwitcher.astro";
import { site } from "../config/site";
import type { Locale } from "../i18n/locales";
import { getLocaleFromPathname, withLocale } from "../i18n/routing";
import { t } from "../i18n/ui";

type Props = {
  title?: string;
  description?: string;
  noIndex?: boolean;
  locale?: Locale;
};

const pathname = Astro.url.pathname;
const locale = Astro.props.locale ?? getLocaleFromPathname(pathname);
const title = Astro.props.title ?? site.titles[locale];
const description = Astro.props.description ?? site.descriptions[locale];
const noIndex = Astro.props.noIndex ?? false;

const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : undefined;
const alternateEn = Astro.site ? new URL(withLocale(pathname, "en"), Astro.site).toString() : undefined;
const alternateEs = Astro.site ? new URL(withLocale(pathname, "es"), Astro.site).toString() : undefined;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    {noIndex ? <meta name="robots" content="noindex,nofollow" /> : null}
    {canonical ? <link rel="canonical" href={canonical} /> : null}
    {alternateEn ? <link rel="alternate" href={alternateEn} hreflang="en" /> : null}
    {alternateEs ? <link rel="alternate" href={alternateEs} hreflang="es" /> : null}
    {alternateEn ? <link rel="alternate" href={alternateEn} hreflang="x-default" /> : null}

    <script is:inline>
      (() => {
        const storageKey = "lfpl47-theme";
        const fallbackTheme = "obsidian";
        const validThemes = new Set(["obsidian", "reactor", "nocturne"]);

        try {
          const savedTheme = localStorage.getItem(storageKey);
          document.documentElement.dataset.theme = validThemes.has(savedTheme) ? savedTheme : fallbackTheme;
        } catch {
          document.documentElement.dataset.theme = fallbackTheme;
        }
      })();
    </script>

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonical ? <meta property="og:url" content={canonical} /> : null}
    <meta property="og:type" content="website" />

    <meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
  </head>
  <body class="site-shell min-h-screen">
    <a class="skip-link" href="#main">
      {t(locale, "skip_to_content")}
    </a>

    <div class="site-ambient" aria-hidden="true">
      <div class="site-ambient__orb site-ambient__orb--primary" />
      <div class="site-ambient__orb site-ambient__orb--secondary" />
      <div class="site-ambient__mesh" />
    </div>

    <SiteHeader />
    <main id="main">
      <slot />
    </main>
    <ThemeSwitcher />
    <SiteFooter />
  </body>
</html>
