---
import { getCollection } from "astro:content";
import Chip from "../../components/Chip.astro";
import Container from "../../components/Container.astro";
import SectionIntro from "../../components/SectionIntro.astro";
import Layout from "../../layouts/Layout.astro";
import { site } from "../../config/site";
import { isSlugForLocale, stripLocaleFromSlug } from "../../i18n/content";
import resume from "../../data/resume.en.json";
import { formatDateRange } from "../../utils/dates";

const locale = "en" as const;
const experience = (await getCollection("experience"))
  .filter((e) => isSlugForLocale(e.slug, locale))
  .sort((a, b) => b.data.start.valueOf() - a.data.start.valueOf());
---

<Layout title={`CV — ${site.handle}`}>
  <section class="py-16 sm:py-20">
    <Container>
      <div class="flex flex-col gap-8 sm:flex-row sm:items-start sm:justify-between">
        <div class="max-w-2xl">
          <SectionIntro kicker="CV" title={resume.basics.name} description={resume.basics.summary} />
        </div>

        <div class="mx-auto sm:mx-0">
          <div class="h-28 w-28 overflow-hidden rounded-full border border-slate-800 bg-slate-950/30 shadow-xl shadow-slate-950/50 sm:h-32 sm:w-32">
            <img
              src={site.avatar.src}
              alt={site.avatar.alt[locale]}
              width="128"
              height="128"
              loading="eager"
              decoding="async"
              class="h-full w-full object-cover"
            />
          </div>
        </div>
      </div>

      <div class="mt-6 flex flex-wrap items-center gap-3 text-sm text-slate-300">
        <span class="rounded-full border border-slate-800 bg-slate-950/30 px-3 py-1.5">
          {resume.basics.label}
        </span>
        <span class="text-slate-500">•</span>
        <span>{resume.basics.location}</span>
        <span class="text-slate-500">•</span>
        <a class="text-sky-300 hover:text-sky-200" href={`mailto:${resume.basics.email}`}>
          {resume.basics.email}
        </a>
      </div>

      <div class="mt-8 flex flex-wrap gap-3">
        <a
          class="rounded-full bg-sky-500 px-5 py-2.5 text-sm font-semibold text-slate-950 hover:bg-sky-400 focus:outline-none focus:ring-2 focus:ring-sky-400/60"
          href={site.cvPdf.en}
        >
          Download PDF
        </a>
        <a
          class="rounded-full border border-slate-800 bg-slate-900/40 px-5 py-2.5 text-sm font-semibold text-slate-100 hover:bg-slate-900"
          href={site.links.linkedin}
          target="_blank"
          rel="noreferrer"
        >
          LinkedIn
        </a>
      </div>

      <div class="mt-12 grid gap-10 lg:grid-cols-[1fr_22rem]">
        <div>
          <h3 class="text-sm font-semibold text-slate-200">Experience</h3>
          <div class="mt-6 space-y-6">
            {experience.map((entry) => (
              <div class="rounded-3xl border border-slate-800 bg-slate-950/30 p-6">
                <div class="flex flex-wrap items-baseline justify-between gap-3">
                  <div>
                    <p class="text-sm font-semibold text-slate-50">{entry.data.role}</p>
                    <p class="text-sm text-slate-400">{entry.data.company}</p>
                  </div>
                  <p class="text-xs text-slate-500">
                    {formatDateRange(entry.data.start, entry.data.end, locale)}
                  </p>
                </div>
                <ul class="mt-4 list-disc space-y-1 pl-5 text-sm text-slate-300">
                  {entry.data.highlights.map((h) => (
                    <li>{h}</li>
                  ))}
                </ul>
                <div class="mt-5">
                  <a
                    class="text-sm font-semibold text-sky-300 hover:text-sky-200"
                    href={`/experience/${stripLocaleFromSlug(entry.slug, locale)}/`}
                  >
                    View details →
                  </a>
                </div>
              </div>
            ))}
          </div>
        </div>

        <aside class="rounded-3xl border border-slate-800 bg-slate-950/30 p-6">
          <div class="space-y-8">
            <div>
              <h3 class="text-sm font-semibold text-slate-200">Skills</h3>
              <div class="mt-4 space-y-6">
                {resume.skills.map((group) => (
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">
                      {group.name}
                    </p>
                    <div class="mt-2 flex flex-wrap gap-2">
                      {group.keywords.map((k) => (
                        <Chip label={k} />
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <div>
              <h3 class="text-sm font-semibold text-slate-200">Education</h3>
              <ul class="mt-4 space-y-4 text-sm text-slate-300">
                {resume.education.map((e) => (
                  <li>
                    <p class="font-semibold text-slate-100">{e.institution}</p>
                    <p class="text-slate-400">{e.studyType} · {e.area}</p>
                    <p class="text-xs text-slate-500">{e.startDate} — {e.endDate}</p>
                  </li>
                ))}
              </ul>
            </div>

            {resume.languages?.length ? (
              <div>
                <h3 class="text-sm font-semibold text-slate-200">Languages</h3>
                <ul class="mt-4 space-y-2 text-sm text-slate-300">
                  {resume.languages.map((l) => (
                    <li class="flex items-baseline justify-between gap-4">
                      <span>{l.name}</span>
                      <span class="text-xs text-slate-500">{l.level}</span>
                    </li>
                  ))}
                </ul>
              </div>
            ) : null}

            {resume.additionalStudies?.length ? (
              <div>
                <h3 class="text-sm font-semibold text-slate-200">Additional studies</h3>
                <ul class="mt-4 list-disc space-y-2 pl-5 text-sm text-slate-300">
                  {resume.additionalStudies.map((s) => (
                    <li>{s}</li>
                  ))}
                </ul>
              </div>
            ) : null}
          </div>
        </aside>
      </div>
    </Container>
  </section>
</Layout>
