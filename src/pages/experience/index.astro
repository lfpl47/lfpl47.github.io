---
import { getCollection } from "astro:content";
import Container from "../../components/Container.astro";
import ExperienceTimelineByYear from "../../components/ExperienceTimelineByYear.astro";
import SectionIntro from "../../components/SectionIntro.astro";
import Layout from "../../layouts/Layout.astro";
import { site } from "../../config/site";
import { isSlugForLocale } from "../../i18n/content";

const locale = "en" as const;
const entries = (await getCollection("experience"))
  .filter((e) => isSlugForLocale(e.slug, locale))
  .sort((a, b) => b.data.start.valueOf() - a.data.start.valueOf());
---

<Layout title={`Experience — ${site.handle}`}>
  <section class="py-16 sm:py-20">
    <Container>
      <SectionIntro
        kicker="Experience"
        title="Timeline"
        description="A timeline of roles and responsibilities, grouped by year — use the year navigation to jump across time."
      />

      <ExperienceTimelineByYear entries={entries} locale={locale} />
    </Container>
  </section>
</Layout>
