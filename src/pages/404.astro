---
import Container from "../components/Container.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout title="Not found — lfpl47" noIndex={true}>
  <section class="py-24">
    <Container class="text-center">
      <p class="text-sm font-semibold text-sky-300/90">404</p>
      <h1 class="mt-4 text-3xl font-semibold tracking-tight text-slate-50">Page not found</h1>
      <p class="mt-4 text-slate-300">
        The page you’re looking for doesn’t exist (or moved).
      </p>
      <div class="mt-10">
        <a
          class="rounded-full bg-sky-500 px-5 py-2.5 text-sm font-semibold text-slate-950 hover:bg-sky-400"
          href="/"
        >
          Go home
        </a>
      </div>
    </Container>
  </section>
</Layout>

