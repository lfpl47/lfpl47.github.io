---
import Layout from "../../layouts/Layout.astro";
import Container from "../../components/Container.astro";
import SectionIntro from "../../components/SectionIntro.astro";
import ExperienceCard from "../../components/ExperienceCard.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import Chip from "../../components/Chip.astro";
import { getCollection } from "astro:content";
import { site } from "../../config/site";
import { isSlugForLocale, stripLocaleFromSlug } from "../../i18n/content";
import { formatDateRange, formatMonthYear } from "../../utils/dates";
import { flattenStack } from "../../utils/stack";

const locale = "es" as const;
const allExperience = (await getCollection("experience")).filter((e) => isSlugForLocale(e.slug, locale));
const allProjects = (await getCollection("projects")).filter((p) => isSlugForLocale(p.slug, locale));

const featuredExperience = allExperience
  .sort(
    (a, b) =>
      Number(b.data.featured ?? false) - Number(a.data.featured ?? false) ||
      b.data.start.valueOf() - a.data.start.valueOf(),
  )
  .slice(0, 2);

const featuredProjects = allProjects
  .sort(
    (a, b) =>
      Number(b.data.featured ?? false) - Number(a.data.featured ?? false) ||
      b.data.date.valueOf() - a.data.date.valueOf(),
  )
  .slice(0, 3);
---

<Layout>
  <section class="py-20 sm:py-28">
    <Container>
      <div class="grid gap-10 lg:grid-cols-[1fr_18rem] lg:items-center">
        <div class="max-w-2xl">
          <p class="text-sm font-semibold text-sky-300/90">{site.location}</p>
          <h1 class="mt-4 text-4xl font-semibold tracking-tight text-slate-50 sm:text-6xl">
            {site.roles.es}.<br />
            <span class="text-slate-300">Entregando productos de datos con impacto.</span>
          </h1>
          <p class="mt-6 text-lg leading-relaxed text-slate-300">{site.summaries.es}</p>

          <div class="mt-10 flex flex-wrap gap-3">
            <a
              class="rounded-full bg-sky-500 px-5 py-2.5 text-sm font-semibold text-slate-950 hover:bg-sky-400 focus:outline-none focus:ring-2 focus:ring-sky-400/60"
              href="/es/projects/"
            >
              Ver casos de estudio
            </a>
            <a
              class="rounded-full border border-slate-800 bg-slate-900/40 px-5 py-2.5 text-sm font-semibold text-slate-100 hover:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-slate-400/30"
              href="/es/experience/"
            >
              Línea de tiempo
            </a>
            <a
              class="rounded-full border border-slate-800 bg-slate-900/40 px-5 py-2.5 text-sm font-semibold text-slate-100 hover:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-slate-400/30"
              href="/es/cv/"
            >
              CV
            </a>
          </div>

          <div class="mt-8 flex flex-wrap gap-2 text-sm text-slate-300">
            <Chip label="Pipelines" />
            <Chip label="Warehouses" />
            <Chip label="dbt / Spark" />
            <Chip label="IaC" />
            <Chip label="Calidad & Observabilidad" />
          </div>
        </div>

        <div class="mx-auto lg:mx-0 lg:justify-self-end">
          <div class="h-44 w-44 overflow-hidden rounded-full border border-slate-800 bg-slate-950/30 shadow-xl shadow-slate-950/50 sm:h-52 sm:w-52">
            <img
              src={site.avatar.src}
              alt={site.avatar.alt[locale]}
              width="208"
              height="208"
              loading="eager"
              decoding="async"
              class="h-full w-full object-cover"
            />
          </div>
        </div>
      </div>
    </Container>
  </section>

  <section class="py-16">
    <Container>
      <SectionIntro
        kicker="Qué hago"
        title="Sistemas de datos confiables, resultados medibles"
        description="Me enfoco en arquitectura y ejecución: pipelines y modelos confiables, con señales claras de calidad y decisiones pragmáticas de costo/performance."
      />

      <div class="mt-10 grid gap-4 sm:grid-cols-3">
        <div class="rounded-3xl border border-slate-800 bg-slate-950/30 p-6">
          <h3 class="text-base font-semibold text-slate-50">Plataformas de datos</h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-300">
            Warehouses por capas, contratos, documentación y ownership para escalar.
          </p>
        </div>
        <div class="rounded-3xl border border-slate-800 bg-slate-950/30 p-6">
          <h3 class="text-base font-semibold text-slate-50">Pipelines & orquestación</h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-300">
            Backfills, SLAs, retries y observabilidad — sin adivinar por qué falló.
          </p>
        </div>
        <div class="rounded-3xl border border-slate-800 bg-slate-950/30 p-6">
          <h3 class="text-base font-semibold text-slate-50">Calidad & confiabilidad</h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-300">
            Tests, lineage y alertas para que los equipos confíen en métricas y decisiones.
          </p>
        </div>
      </div>
    </Container>
  </section>

  <section class="py-16">
    <Container>
      <div class="flex flex-wrap items-end justify-between gap-6">
        <SectionIntro
          kicker="Experiencia"
          title="Roles destacados"
          description="Una línea de tiempo enfocada en impacto: stack, resultados y entregables."
        />
        <a class="text-sm font-semibold text-sky-300 hover:text-sky-200" href="/es/experience/">
          Ver todo →
        </a>
      </div>

      <div class="mt-10 grid gap-4">
        {
          featuredExperience.map((entry) => (
            <ExperienceCard
              href={`/es/experience/${stripLocaleFromSlug(entry.slug, locale)}/`}
              company={entry.data.company}
              role={entry.data.role}
              dateRange={formatDateRange(entry.data.start, entry.data.end, locale)}
              location={entry.data.location}
              highlights={entry.data.highlights}
              tags={[...(entry.data.tags ?? []), ...flattenStack(entry.data.stack)].slice(0, 12)}
            />
          ))
        }
      </div>
    </Container>
  </section>

  <section class="py-16">
    <Container>
      <div class="flex flex-wrap items-end justify-between gap-6">
        <SectionIntro
          kicker="Proyectos"
          title="Casos de estudio"
          description="Problema → solución → arquitectura → tradeoffs → resultados."
        />
        <a class="text-sm font-semibold text-sky-300 hover:text-sky-200" href="/es/projects/">
          Ver todo →
        </a>
      </div>

      <div class="mt-10 grid gap-4 sm:grid-cols-2">
        {featuredProjects.length ? (
          featuredProjects.map((entry) => (
            <ProjectCard
              href={`/es/projects/${stripLocaleFromSlug(entry.slug, locale)}/`}
              title={entry.data.title}
              dateLabel={formatMonthYear(entry.data.date, locale)}
              type={entry.data.type}
              status={entry.data.status}
              highlights={entry.data.highlights}
              tags={[...(entry.data.tags ?? []), ...flattenStack(entry.data.stack)].slice(0, 12)}
            />
          ))
        ) : (
          <div class="rounded-3xl border border-slate-800 bg-slate-950/30 p-6 text-slate-300">
            <p class="text-sm font-semibold text-slate-200">Aún no hay proyectos</p>
            <p class="mt-2 text-sm text-slate-400">
              Agrega casos de estudio desde{" "}
              <a class="text-sky-300 hover:text-sky-200" href="/admin/">/admin</a>.
            </p>
          </div>
        )}
      </div>
    </Container>
  </section>
</Layout>
