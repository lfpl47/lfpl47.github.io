---
import Layout from "../../layouts/Layout.astro";
import Container from "../../components/Container.astro";
import SectionIntro from "../../components/SectionIntro.astro";
import Chip from "../../components/Chip.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import { site } from "../../config/site";
import { isSlugForLocale, stripLocaleFromSlug } from "../../i18n/content";
import { formatMonthYear } from "../../utils/dates";
import { flattenStack } from "../../utils/stack";

const locale = "es" as const;
const allExperience = (await getCollection("experience")).filter((e) => isSlugForLocale(e.slug, locale));
const allProjects = (await getCollection("projects")).filter((p) => isSlugForLocale(p.slug, locale));

const featuredProjects = allProjects
  .sort(
    (a, b) =>
      Number(b.data.featured ?? false) - Number(a.data.featured ?? false) ||
      b.data.date.valueOf() - a.data.date.valueOf(),
  )
  .slice(0, 3);

type TrackId = "analytics" | "development" | "engineering";
type ExperienceEntry = CollectionEntry<"experience">;

function trackForRole(role: string): TrackId {
  const r = role.toLowerCase();
  if (
    r.includes("ingeniero de datos") ||
    r.includes("data engineer") ||
    r.includes("data engineering") ||
    r.includes("engineering")
  ) {
    return "engineering";
  }
  if (r.includes("web master") || r.includes("developer") || r.includes("desarrollador") || r.includes("backend")) {
    return "development";
  }
  if (r.includes("analista") || r.includes("analyst") || r.includes("analytics") || r.includes("estrategia") || r.includes("wfm")) {
    return "analytics";
  }
  return "engineering";
}

const experienceByTrack: Record<TrackId, ExperienceEntry[]> = {
  analytics: [],
  development: [],
  engineering: [],
};

for (const entry of allExperience) {
  experienceByTrack[trackForRole(entry.data.role)].push(entry);
}

function yearSpan(entries: ExperienceEntry[]): string | null {
  if (!entries.length) return null;
  const startYear = Math.min(...entries.map((e) => e.data.start.getFullYear()));
  const endYear = entries.some((e) => !e.data.end)
    ? "Actual"
    : Math.max(...entries.map((e) => (e.data.end ?? e.data.start).getFullYear()));
  return `${startYear}—${endYear}`;
}

function topChips(entries: ExperienceEntry[], max = 4): string[] {
  const counts = new Map<string, number>();
  for (const entry of entries) {
    for (const label of flattenStack(entry.data.stack)) {
      counts.set(label, (counts.get(label) ?? 0) + 1);
    }
  }

  return [...counts.entries()]
    .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
    .map(([label]) => label)
    .slice(0, max);
}

const careerTracks = [
  {
    id: "analytics" as const,
    label: "Analítica de datos",
    description: "Reporting, dashboards, KPIs y soporte a decisiones.",
  },
  {
    id: "development" as const,
    label: "Desarrollo de datos",
    description: "Automatización, integraciones y bases backend para productos de datos.",
  },
  {
    id: "engineering" as const,
    label: "Ingeniería de datos",
    description: "Plataformas cloud, pipelines, orquestación y entrega confiable.",
  },
];
---

<Layout>
  <section class="py-20 sm:py-28">
    <Container>
      <div class="grid gap-10 lg:grid-cols-[1fr_18rem] lg:items-center">
        <div class="max-w-2xl">
          <p class="text-sm font-semibold text-sky-300/90">{site.location}</p>
          <h1 class="mt-4 text-4xl font-semibold tracking-tight text-slate-50 sm:text-6xl">
            {site.roles.es}
          </h1>
          <p class="mt-3 text-sm font-semibold text-slate-300">{site.roleDeck.es}</p>
          <p class="mt-5 text-lg leading-relaxed text-slate-300">{site.summaries.es}</p>
        </div>

        <div class="mx-auto lg:mx-0 lg:justify-self-center">
          <div class="h-44 w-44 overflow-hidden rounded-full border border-slate-800 bg-slate-950/30 shadow-xl shadow-slate-950/50 sm:h-52 sm:w-52">
            <img
              src={site.avatar.src}
              alt={site.avatar.alt[locale]}
              width="208"
              height="208"
              loading="eager"
              decoding="async"
              class="h-full w-full object-cover"
            />
          </div>
        </div>
      </div>
    </Container>
  </section>

  <section class="py-16">
    <Container>
      <SectionIntro
        kicker="Qué hago"
        title="Sistemas de datos confiables, resultados medibles"
        description="Me enfoco en arquitectura y ejecución: pipelines y modelos confiables, con señales claras de calidad y decisiones pragmáticas de costo/performance."
      />

      <div class="mt-10 grid gap-4 sm:grid-cols-3">
        <div class="rounded-3xl border border-slate-800 bg-slate-950/30 p-6">
          <div class="flex items-start gap-3">
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl border border-slate-800 bg-slate-950/40 text-sky-300">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="h-5 w-5"
                aria-hidden="true"
              >
                <path d="M20.25 6.375c0 2.485-4.03 4.5-9 4.5s-9-2.015-9-4.5 4.03-4.5 9-4.5 9 2.015 9 4.5Z" />
                <path d="M4.5 6.375v11.25c0 2.485 4.03 4.5 9 4.5s9-2.015 9-4.5V6.375" />
                <path d="M4.5 11.625c0 2.485 4.03 4.5 9 4.5s9-2.015 9-4.5" />
                <path d="M4.5 16.875c0 2.485 4.03 4.5 9 4.5s9-2.015 9-4.5" />
              </svg>
            </span>
            <h3 class="text-base font-semibold text-slate-50">Plataformas de datos</h3>
          </div>
          <p class="mt-3 text-sm leading-relaxed text-slate-300">
            Warehouses por capas, contratos, documentación y ownership para escalar.
          </p>
        </div>
        <div class="rounded-3xl border border-slate-800 bg-slate-950/30 p-6">
          <div class="flex items-start gap-3">
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl border border-slate-800 bg-slate-950/40 text-sky-300">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="h-5 w-5"
                aria-hidden="true"
              >
                <path d="M16.023 9.348h4.992v-.001" />
                <path d="M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7" />
                <path d="M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
              </svg>
            </span>
            <h3 class="text-base font-semibold text-slate-50">Pipelines & orquestación</h3>
          </div>
          <p class="mt-3 text-sm leading-relaxed text-slate-300">
            Backfills, SLAs, retries y observabilidad — sin adivinar por qué falló.
          </p>
        </div>
        <div class="rounded-3xl border border-slate-800 bg-slate-950/30 p-6">
          <div class="flex items-start gap-3">
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl border border-slate-800 bg-slate-950/40 text-sky-300">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="h-5 w-5"
                aria-hidden="true"
              >
                <path d="M9 12.75 11.25 15 15 9.75" />
                <path d="M21 12c0 7.5-9 9.75-9 9.75S3 19.5 3 12V5.25L12 2.25l9 3V12Z" />
              </svg>
            </span>
            <h3 class="text-base font-semibold text-slate-50">Calidad & confiabilidad</h3>
          </div>
          <p class="mt-3 text-sm leading-relaxed text-slate-300">
            Tests, lineage y alertas para que los equipos confíen en métricas y decisiones.
          </p>
        </div>
      </div>
    </Container>
  </section>

  <section class="py-16">
    <Container>
      <div class="flex flex-wrap items-end justify-between gap-6">
        <SectionIntro
          kicker="Experiencia"
          title="Resumen de carrera"
          description="Un vistazo rápido a mi trayectoria — la línea de tiempo completa está en Experiencia."
        />
        <a class="text-sm font-semibold text-sky-300 hover:text-sky-200" href="/es/experience/">
          Ver todo →
        </a>
      </div>

      <div class="mt-10 grid gap-4 sm:grid-cols-3">
        {careerTracks.map((track) => {
          const entries = experienceByTrack[track.id];
          const span = yearSpan(entries);
          const chips = topChips(entries);

          return (
            <a
              class="group block rounded-3xl border border-slate-800 bg-slate-950/30 p-6 transition hover:border-slate-700 hover:bg-slate-900/30"
              href="/es/experience/"
            >
              <div class="flex items-start gap-3">
                <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl border border-slate-800 bg-slate-950/40 text-sky-300">
                  {track.id === "analytics" ? (
                    <svg
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.8"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="h-5 w-5"
                      aria-hidden="true"
                    >
                      <path d="M4 19V5" />
                      <path d="M4 19h16" />
                      <path d="M8 15v-6" />
                      <path d="M12 15V9" />
                      <path d="M16 15v-3" />
                    </svg>
                  ) : track.id === "development" ? (
                    <svg
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.8"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="h-5 w-5"
                      aria-hidden="true"
                    >
                      <path d="m10 8-4 4 4 4" />
                      <path d="m14 16 4-4-4-4" />
                      <path d="M12 6 10 18" />
                    </svg>
                  ) : (
                    <svg
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.8"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="h-5 w-5"
                      aria-hidden="true"
                    >
                      <path d="M7.5 18a4.5 4.5 0 0 1 0-9 6 6 0 0 1 11.5 1.5A3.5 3.5 0 0 1 18.5 18H7.5Z" />
                    </svg>
                  )}
                </span>

                <div class="min-w-0">
                  <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">
                    {entries.length} roles{span ? ` · ${span}` : ""}
                  </p>
                  <h3 class="mt-1 text-sm font-semibold text-slate-50">{track.label}</h3>
                </div>
              </div>

              <p class="mt-3 text-sm leading-relaxed text-slate-300">{track.description}</p>

              {chips.length ? (
                <div class="mt-4 flex flex-wrap gap-2">
                  {chips.map((c) => (
                    <Chip label={c} />
                  ))}
                </div>
              ) : null}

              <p class="mt-5 text-sm font-semibold text-sky-300 opacity-0 transition group-hover:opacity-100">
                Ver línea de tiempo →
              </p>
            </a>
          );
        })}
      </div>
    </Container>
  </section>

  <section class="py-16">
    <Container>
      <div class="flex flex-wrap items-end justify-between gap-6">
        <SectionIntro
          kicker="Proyectos"
          title="Casos de estudio"
          description="Problema → solución → arquitectura → tradeoffs → resultados."
        />
        <a class="text-sm font-semibold text-sky-300 hover:text-sky-200" href="/es/projects/">
          Ver todo →
        </a>
      </div>

      <div class="mt-10 grid gap-4 sm:grid-cols-2">
        {featuredProjects.length ? (
          featuredProjects.map((entry) => (
            <ProjectCard
              href={`/es/projects/${stripLocaleFromSlug(entry.slug, locale)}/`}
              title={entry.data.title}
              dateLabel={formatMonthYear(entry.data.date, locale)}
              type={entry.data.type}
              status={entry.data.status}
              highlights={entry.data.highlights}
              tags={[...(entry.data.tags ?? []), ...flattenStack(entry.data.stack)].slice(0, 12)}
            />
          ))
        ) : (
          <div class="rounded-3xl border border-slate-800 bg-slate-950/30 p-6 text-slate-300">
            <p class="text-sm font-semibold text-slate-200">Aún no hay proyectos</p>
            <p class="mt-2 text-sm text-slate-400">
              Agrega casos de estudio desde{" "}
              <a class="text-sky-300 hover:text-sky-200" href="/admin/">/admin</a>.
            </p>
          </div>
        )}
      </div>
    </Container>
  </section>
</Layout>
