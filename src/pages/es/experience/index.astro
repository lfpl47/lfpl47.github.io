---
import { getCollection } from "astro:content";
import Container from "../../../components/Container.astro";
import ExperienceTimelineByYear from "../../../components/ExperienceTimelineByYear.astro";
import SectionIntro from "../../../components/SectionIntro.astro";
import Layout from "../../../layouts/Layout.astro";
import { site } from "../../../config/site";
import { isSlugForLocale } from "../../../i18n/content";

const locale = "es" as const;
const entries = (await getCollection("experience"))
  .filter((e) => isSlugForLocale(e.slug, locale))
  .sort((a, b) => b.data.start.valueOf() - a.data.start.valueOf());
---

<Layout title={`Experiencia — ${site.handle}`}>
  <section class="py-16 sm:py-20">
    <Container>
      <SectionIntro
        kicker="Experiencia"
        title="Línea de tiempo"
        description="Una línea de tiempo de roles y responsabilidades, agrupada por año — usa los años para saltar rápidamente en el tiempo."
      >
        <span slot="title" class="inline-flex items-center gap-3">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-7 w-7 text-sky-300"
            aria-hidden="true"
          >
            <circle cx="7" cy="6" r="1.75" />
            <circle cx="7" cy="12" r="1.75" />
            <circle cx="7" cy="18" r="1.75" />
            <path d="M7 7.75v2.5" />
            <path d="M7 13.75v2.5" />
            <path d="M11 6h10" />
            <path d="M11 12h10" />
            <path d="M11 18h10" />
          </svg>
          <span>Línea de tiempo</span>
        </span>
      </SectionIntro>

      <ExperienceTimelineByYear entries={entries} locale={locale} />
    </Container>
  </section>
</Layout>
