---
import { getCollection } from "astro:content";
import Container from "../../../components/Container.astro";
import ExperienceCard from "../../../components/ExperienceCard.astro";
import SectionIntro from "../../../components/SectionIntro.astro";
import Layout from "../../../layouts/Layout.astro";
import { site } from "../../../config/site";
import { isSlugForLocale, stripLocaleFromSlug } from "../../../i18n/content";
import { formatDateRange } from "../../../utils/dates";
import { flattenStack } from "../../../utils/stack";

const locale = "es" as const;
const entries = (await getCollection("experience"))
  .filter((e) => isSlugForLocale(e.slug, locale))
  .sort((a, b) => b.data.start.valueOf() - a.data.start.valueOf());
---

<Layout title={`Experiencia — ${site.handle}`}>
  <section class="py-16 sm:py-20">
    <Container>
      <SectionIntro
        kicker="Experiencia"
        title="Línea de tiempo"
        description="Una línea de tiempo de roles y responsabilidades — abre cada entry para ver stack, highlights y detalles."
      />

      <ul class="mt-10 grid gap-4">
        {
          entries.map((entry) => {
            const tags = [...(entry.data.tags ?? []), ...flattenStack(entry.data.stack)];

            return (
              <li>
                <ExperienceCard
                  href={`/es/experience/${stripLocaleFromSlug(entry.slug, locale)}/`}
                  company={entry.data.company}
                  role={entry.data.role}
                  dateRange={formatDateRange(entry.data.start, entry.data.end, locale)}
                  location={entry.data.location}
                  highlights={entry.data.highlights}
                  tags={tags}
                />
              </li>
            );
          })
        }
      </ul>
    </Container>
  </section>
</Layout>
