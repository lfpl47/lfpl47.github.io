---
import { getCollection } from "astro:content";
import Container from "../../../components/Container.astro";
import ExperienceTimelineByYear from "../../../components/ExperienceTimelineByYear.astro";
import SectionIntro from "../../../components/SectionIntro.astro";
import Layout from "../../../layouts/Layout.astro";
import { site } from "../../../config/site";
import { isSlugForLocale } from "../../../i18n/content";

const locale = "es" as const;
const entries = (await getCollection("experience"))
  .filter((e) => isSlugForLocale(e.slug, locale))
  .sort((a, b) => b.data.start.valueOf() - a.data.start.valueOf());
---

<Layout title={`Experiencia — ${site.handle}`}>
  <section class="py-16 sm:py-20">
    <Container>
      <SectionIntro
        kicker="Experiencia"
        title="Línea de tiempo"
        description="Una línea de tiempo de roles y responsabilidades, agrupada por año — usa los años para saltar rápidamente en el tiempo."
      />

      <ExperienceTimelineByYear entries={entries} locale={locale} />
    </Container>
  </section>
</Layout>
