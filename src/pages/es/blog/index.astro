---
import { getCollection } from "astro:content";
import Container from "../../../components/Container.astro";
import SectionIntro from "../../../components/SectionIntro.astro";
import Layout from "../../../layouts/Layout.astro";
import { site } from "../../../config/site";
import { isSlugForLocale, stripLocaleFromSlug } from "../../../i18n/content";
import { formatMonthYear } from "../../../utils/dates";

const locale = "es" as const;
const posts = (await getCollection("posts"))
  .filter((p) => isSlugForLocale(p.slug, locale))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title={`Blog — ${site.handle}`} description="Posts técnicos cortos sobre data engineering.">
  <section class="py-16 sm:py-20">
    <Container>
      <SectionIntro
        kicker="Blog"
        title="Notas & write-ups"
        description="Posts técnicos cortos para documentar aprendizajes y mostrar cómo pienso."
      />

      {posts.length ? (
        <ul class="mt-10 grid gap-4">
          {posts.map((post) => (
            <li>
              <a
                class="block rounded-3xl border border-slate-800 bg-slate-950/30 p-6 hover:bg-slate-900/30"
                href={`/es/blog/${stripLocaleFromSlug(post.slug, locale)}/`}
              >
                <p class="text-sm text-slate-400">{formatMonthYear(post.data.date, locale)}</p>
                <h3 class="mt-2 text-lg font-semibold text-slate-50">{post.data.title}</h3>
                {post.data.description ? (
                  <p class="mt-2 text-sm text-slate-300">{post.data.description}</p>
                ) : null}
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="mt-8 text-slate-300">Aún no hay publicaciones.</p>
      )}
    </Container>
  </section>
</Layout>
