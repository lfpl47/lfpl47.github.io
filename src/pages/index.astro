---
import Layout from "../layouts/Layout.astro";
import Container from "../components/Container.astro";
import SectionIntro from "../components/SectionIntro.astro";
import ExperienceCard from "../components/ExperienceCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { getCollection } from "astro:content";
import { site } from "../config/site";
import { isSlugForLocale, stripLocaleFromSlug } from "../i18n/content";
import { formatDateRange, formatMonthYear } from "../utils/dates";
import { flattenStack } from "../utils/stack";

const locale = "en" as const;
const allExperience = (await getCollection("experience")).filter((e) => isSlugForLocale(e.slug, locale));
const allProjects = (await getCollection("projects")).filter((p) => isSlugForLocale(p.slug, locale));

const featuredExperience = allExperience
  .sort(
    (a, b) =>
      Number(b.data.featured ?? false) - Number(a.data.featured ?? false) ||
      b.data.start.valueOf() - a.data.start.valueOf(),
  )
  .slice(0, 2);

const featuredProjects = allProjects
  .sort(
    (a, b) =>
      Number(b.data.featured ?? false) - Number(a.data.featured ?? false) ||
      b.data.date.valueOf() - a.data.date.valueOf(),
  )
  .slice(0, 3);
---

<Layout>
  <section class="py-20 sm:py-28">
    <Container>
      <div class="grid gap-10 lg:grid-cols-[1fr_18rem] lg:items-center">
        <div class="max-w-2xl">
          <p class="text-sm font-semibold text-sky-300/90">{site.location}</p>
          <h1 class="mt-4 text-4xl font-semibold tracking-tight text-slate-50 sm:text-6xl">
            {site.roles.en}
          </h1>
          <p class="mt-3 text-sm font-semibold text-slate-300">{site.roleDeck.en}</p>
          <p class="mt-5 text-lg leading-relaxed text-slate-300">{site.summaries.en}</p>
        </div>

        <div class="mx-auto lg:mx-0 lg:justify-self-center">
          <div class="h-44 w-44 overflow-hidden rounded-full border border-slate-800 bg-slate-950/30 shadow-xl shadow-slate-950/50 sm:h-52 sm:w-52">
            <img
              src={site.avatar.src}
              alt={site.avatar.alt[locale]}
              width="208"
              height="208"
              loading="eager"
              decoding="async"
              class="h-full w-full object-cover"
            />
          </div>
        </div>
      </div>
    </Container>
  </section>

  <section class="py-16">
    <Container>
      <SectionIntro
        kicker="What I do"
        title="Reliable data systems, measurable outcomes"
        description="I focus on architecture and execution: shipping pipelines and models that teams trust, with strong quality signals and pragmatic cost/performance choices."
      />

      <div class="mt-10 grid gap-4 sm:grid-cols-3">
        <div class="rounded-3xl border border-slate-800 bg-slate-950/30 p-6">
          <div class="flex items-start gap-3">
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl border border-slate-800 bg-slate-950/40 text-sky-300">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="h-5 w-5"
                aria-hidden="true"
              >
                <path d="M20.25 6.375c0 2.485-4.03 4.5-9 4.5s-9-2.015-9-4.5 4.03-4.5 9-4.5 9 2.015 9 4.5Z" />
                <path d="M4.5 6.375v11.25c0 2.485 4.03 4.5 9 4.5s9-2.015 9-4.5V6.375" />
                <path d="M4.5 11.625c0 2.485 4.03 4.5 9 4.5s9-2.015 9-4.5" />
                <path d="M4.5 16.875c0 2.485 4.03 4.5 9 4.5s9-2.015 9-4.5" />
              </svg>
            </span>
            <h3 class="text-base font-semibold text-slate-50">Data platforms</h3>
          </div>
          <p class="mt-3 text-sm leading-relaxed text-slate-300">
            Layered warehouses, data contracts, documentation, and ownership that scale.
          </p>
        </div>
        <div class="rounded-3xl border border-slate-800 bg-slate-950/30 p-6">
          <div class="flex items-start gap-3">
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl border border-slate-800 bg-slate-950/40 text-sky-300">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="h-5 w-5"
                aria-hidden="true"
              >
                <path d="M16.023 9.348h4.992v-.001" />
                <path d="M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7" />
                <path d="M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
              </svg>
            </span>
            <h3 class="text-base font-semibold text-slate-50">Pipelines & orchestration</h3>
          </div>
          <p class="mt-3 text-sm leading-relaxed text-slate-300">
            Backfills, SLAs, retries, and observability — without guessing why things broke.
          </p>
        </div>
        <div class="rounded-3xl border border-slate-800 bg-slate-950/30 p-6">
          <div class="flex items-start gap-3">
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl border border-slate-800 bg-slate-950/40 text-sky-300">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="h-5 w-5"
                aria-hidden="true"
              >
                <path d="M9 12.75 11.25 15 15 9.75" />
                <path d="M21 12c0 7.5-9 9.75-9 9.75S3 19.5 3 12V5.25L12 2.25l9 3V12Z" />
              </svg>
            </span>
            <h3 class="text-base font-semibold text-slate-50">Quality & reliability</h3>
          </div>
          <p class="mt-3 text-sm leading-relaxed text-slate-300">
            Tests, lineage, and alerting so stakeholders can trust metrics and decisions.
          </p>
        </div>
      </div>
    </Container>
  </section>

  <section class="py-16">
    <Container>
      <div class="flex flex-wrap items-end justify-between gap-6">
        <div>
          <SectionIntro
            kicker="Experience"
            title="Selected roles"
            description="A timeline of impact-focused work: stack, outcomes, and what shipped."
          />
          <p class="mt-3 text-sm text-slate-400">
            Career progression: Data Analyst → Backend Developer → Data Engineer
          </p>
        </div>
        <a class="text-sm font-semibold text-sky-300 hover:text-sky-200" href="/experience/">
          View all →
        </a>
      </div>

      <div class="mt-10 grid gap-4">
        {
          featuredExperience.map((entry) => (
            <ExperienceCard
              href={`/experience/${stripLocaleFromSlug(entry.slug, locale)}/`}
              company={entry.data.company}
              role={entry.data.role}
              dateRange={formatDateRange(entry.data.start, entry.data.end, locale)}
              location={entry.data.location}
              highlights={entry.data.highlights}
              tags={[...(entry.data.tags ?? []), ...flattenStack(entry.data.stack)].slice(0, 12)}
            />
          ))
        }
      </div>
    </Container>
  </section>

  <section class="py-16">
    <Container>
      <div class="flex flex-wrap items-end justify-between gap-6">
        <SectionIntro
          kicker="Projects"
          title="Case studies"
          description="Problem → solution → architecture → tradeoffs → results."
        />
        <a class="text-sm font-semibold text-sky-300 hover:text-sky-200" href="/projects/">
          View all →
        </a>
      </div>

      <div class="mt-10 grid gap-4 sm:grid-cols-2">
        {featuredProjects.length ? (
          featuredProjects.map((entry) => (
            <ProjectCard
              href={`/projects/${stripLocaleFromSlug(entry.slug, locale)}/`}
              title={entry.data.title}
              dateLabel={formatMonthYear(entry.data.date, locale)}
              type={entry.data.type}
              status={entry.data.status}
              highlights={entry.data.highlights}
              tags={[...(entry.data.tags ?? []), ...flattenStack(entry.data.stack)].slice(0, 12)}
            />
          ))
        ) : (
          <div class="rounded-3xl border border-slate-800 bg-slate-950/30 p-6 text-slate-300">
            <p class="text-sm font-semibold text-slate-200">No projects yet</p>
            <p class="mt-2 text-sm text-slate-400">
              Add case studies via <a class="text-sky-300 hover:text-sky-200" href="/admin/">/admin</a>.
            </p>
          </div>
        )}
      </div>
    </Container>
  </section>
</Layout>
