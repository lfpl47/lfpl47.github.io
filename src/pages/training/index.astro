---
import Container from "../../components/Container.astro";
import SectionIntro from "../../components/SectionIntro.astro";
import Layout from "../../layouts/Layout.astro";
import { site } from "../../config/site";
import resume from "../../data/resume.en.json";
import certifications from "../../data/certifications.json";

const locale = "en" as const;

const items = certifications.items;
const folderLabelByKey = new Map(certifications.folders.map((f) => [f.key, f.labels[locale]]));
const tagOptions = certifications.folders.map((f) => ({ id: f.key, label: f.labels[locale], url: f.url }));
---

<Layout title={`Training — ${site.handle}`}>
  <section class="py-16 sm:py-20">
    <Container>
      <SectionIntro
        kicker="Training"
        title="Education & certifications"
        description="Academic background and complementary learning. Certificates are stored in Google Drive."
      />

      <div class="mt-10 grid gap-4 lg:grid-cols-2">
        <div class="rounded-3xl border border-slate-800 bg-slate-950/30 p-6">
          <h3 class="text-sm font-semibold text-slate-200">Academic education</h3>
          <ul class="mt-4 space-y-4 text-sm text-slate-300">
            {resume.education.map((e) => (
              <li>
                <p class="font-semibold text-slate-100">{e.institution}</p>
                <p class="text-slate-400">
                  {e.studyType} · {e.area}
                </p>
                <p class="text-xs text-slate-500">
                  {e.startDate} — {e.endDate}
                </p>
              </li>
            ))}
          </ul>
        </div>

        <div class="rounded-3xl border border-slate-800 bg-slate-950/30 p-6">
          <h3 class="text-sm font-semibold text-slate-200">Complementary studies</h3>
          <ul class="mt-4 list-disc space-y-2 pl-5 text-sm text-slate-300">
            {resume.additionalStudies?.map((s) => (
              <li>{s}</li>
            ))}
          </ul>
        </div>
      </div>

      <div class="mt-14">
        <div class="flex flex-wrap items-end justify-between gap-6">
          <div>
            <p class="text-sm font-semibold text-sky-300/90">Certifications</p>
            <h2 class="mt-3 text-2xl font-semibold tracking-tight text-slate-50 sm:text-3xl">
              Browse certificates
            </h2>
            <p class="mt-3 max-w-2xl text-sm leading-relaxed text-slate-300">
              Use the search box and category filters. Each item opens the certificate in a new tab.
            </p>
          </div>
          <div class="flex flex-wrap gap-2">
            {tagOptions.map((f) => (
              <a
                class="rounded-full border border-slate-800 bg-slate-900/30 px-3 py-1.5 text-xs font-semibold text-slate-200 hover:bg-slate-900"
                href={f.url}
                target="_blank"
                rel="noreferrer"
              >
                Open {f.label} →
              </a>
            ))}
          </div>
        </div>

        <div class="mt-10 rounded-3xl border border-slate-800 bg-slate-950/30 p-4 sm:p-6">
          <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <label class="flex-1">
              <span class="sr-only">Search certifications</span>
              <input
                id="search"
                type="search"
                placeholder="Search (title, category…) "
                class="w-full rounded-2xl border border-slate-800 bg-slate-950/50 px-4 py-2.5 text-sm text-slate-100 placeholder:text-slate-500 focus:outline-none focus:ring-2 focus:ring-sky-400/40"
              />
            </label>

            <div class="flex flex-wrap items-center gap-3">
              <p id="results" class="text-sm text-slate-400">{items.length} certificates</p>
              <button
                id="clear"
                type="button"
                class="rounded-full border border-slate-800 bg-slate-900/40 px-4 py-2 text-sm font-semibold text-slate-100 hover:bg-slate-900"
              >
                Clear
              </button>
            </div>
          </div>

          <div class="mt-4 flex flex-wrap gap-2">
            {tagOptions.map((tag) => (
              <button
                type="button"
                data-filter-tag={tag.id}
                aria-pressed="false"
                class="rounded-full border border-slate-800 bg-slate-900/30 px-3 py-1.5 text-xs font-semibold text-slate-200 hover:bg-slate-900"
              >
                {tag.label}
              </button>
            ))}
          </div>
        </div>

        <ul class="mt-10 grid gap-4 sm:grid-cols-2">
          {items.map((item) => {
            const category = folderLabelByKey.get(item.folderKey) ?? item.folderKey;
            const text = `${item.title} ${category}`.toLowerCase();

            return (
              <li data-filter-item data-tags={item.folderKey} data-text={text}>
                <a
                  class="block rounded-3xl border border-slate-800 bg-slate-950/30 p-6 hover:bg-slate-900/30"
                  href={item.url}
                  target="_blank"
                  rel="noreferrer"
                >
                  <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">{category}</p>
                  <h3 class="mt-2 text-sm font-semibold text-slate-50">{item.title}</h3>
                  <p class="mt-4 text-sm font-semibold text-sky-300">View →</p>
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    </Container>
  </section>

  <script is:inline>
    (() => {
      const selected = new Set();
      const items = Array.from(document.querySelectorAll("[data-filter-item]"));
      const tagButtons = Array.from(document.querySelectorAll("[data-filter-tag]"));
      const search = document.getElementById("search");
      const clear = document.getElementById("clear");
      const results = document.getElementById("results");

      const inactiveClasses = ["bg-slate-900/30", "text-slate-200", "border-slate-800"];
      const activeClasses = ["bg-sky-500", "text-slate-950", "border-sky-400"];

      function setActive(btn, active) {
        btn.setAttribute("aria-pressed", active ? "true" : "false");
        for (const c of inactiveClasses) btn.classList.toggle(c, !active);
        for (const c of activeClasses) btn.classList.toggle(c, active);
      }

      function apply() {
        const query = (search?.value || "").trim().toLowerCase();
        let visible = 0;

        for (const el of items) {
          const tags = (el.getAttribute("data-tags") || "").split(" ").filter(Boolean);
          const text = el.getAttribute("data-text") || "";
          const matchesQuery = !query || text.includes(query);
          const matchesTags = Array.from(selected).every((t) => tags.includes(t));
          const show = matchesQuery && matchesTags;
          el.hidden = !show;
          if (show) visible += 1;
        }

        if (results) results.textContent = `${visible} / ${items.length} certificates`;
      }

      for (const btn of tagButtons) {
        btn.addEventListener("click", () => {
          const tag = btn.getAttribute("data-filter-tag");
          if (!tag) return;
          const next = !selected.has(tag);
          if (next) selected.add(tag);
          else selected.delete(tag);
          setActive(btn, next);
          apply();
        });
      }

      search?.addEventListener("input", apply);
      clear?.addEventListener("click", () => {
        selected.clear();
        for (const btn of tagButtons) setActive(btn, false);
        if (search) search.value = "";
        apply();
      });

      apply();
    })();
  </script>
</Layout>

