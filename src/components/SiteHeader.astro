---
import Container from "./Container.astro";
import { site } from "../config/site";
import { getLocaleFromPathname, otherLocale, withLocale } from "../i18n/routing";
import { t } from "../i18n/ui";

const pathname = Astro.url.pathname;
const locale = getLocaleFromPathname(pathname);
const targetLocale = otherLocale(locale);
const toggleHref = withLocale(pathname, targetLocale);

const homeHref = withLocale("/", locale);
const nav = [
  { href: homeHref, label: t(locale, "home") },
  { href: withLocale("/experience/", locale), label: t(locale, "experience") },
  { href: withLocale("/projects/", locale), label: t(locale, "projects") },
  { href: withLocale("/training/", locale), label: t(locale, "training") },
  { href: withLocale("/cv/", locale), label: t(locale, "cv") },
];

function isActive(href: string) {
  if (href === homeHref) return pathname === homeHref;
  return pathname.startsWith(href);
}
---

<header class="sticky top-0 z-50 border-b border-slate-800/60 bg-slate-950/70 backdrop-blur">
  <Container class="flex h-16 items-center justify-between gap-4">
    <a class="flex items-center gap-2 font-semibold tracking-tight text-slate-100 hover:text-white" href={homeHref}>
      <img
        src={site.avatar.src}
        alt={site.avatar.alt[locale]}
        width="32"
        height="32"
        loading="eager"
        decoding="async"
        class="h-8 w-8 rounded-full border border-slate-800 object-cover"
      />
      <span>{site.handle}</span>
    </a>

    <nav class="hidden items-center gap-1 sm:flex" aria-label="Primary">
      {
        nav.map((item) => (
          <a
            class:list={[
              "rounded-full px-3 py-1.5 text-sm font-medium transition",
              isActive(item.href)
                ? "bg-slate-900 text-white"
                : "text-slate-300 hover:bg-slate-900/60 hover:text-white",
            ]}
            href={item.href}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="hidden items-center gap-2 sm:flex">
      <a
        class="rounded-full border border-slate-800 bg-slate-900/40 px-3 py-1.5 text-sm font-semibold text-slate-100 hover:bg-slate-900"
        href={site.links.github}
        target="_blank"
        rel="noreferrer"
      >
        {t(locale, "github")}
      </a>
      {
        site.links.linkedin ? (
          <a
            class="rounded-full border border-slate-800 bg-slate-900/40 px-3 py-1.5 text-sm font-semibold text-slate-100 hover:bg-slate-900"
            href={site.links.linkedin}
            target="_blank"
            rel="noreferrer"
          >
            {t(locale, "linkedin")}
          </a>
        ) : null
      }
      <a
        class="rounded-full border border-slate-800 bg-slate-900/40 px-3 py-1.5 text-sm font-semibold text-slate-100 hover:bg-slate-900"
        href={toggleHref}
        aria-label={`${t(locale, "language")}: ${targetLocale === "es" ? t(locale, "language_es") : t(locale, "language_en")}`}
        lang={targetLocale}
      >
        {targetLocale.toUpperCase()}
      </a>
    </div>

    <details class="relative sm:hidden">
      <summary class="list-none rounded-full border border-slate-800 bg-slate-900/40 px-3 py-1.5 text-sm font-semibold text-slate-100 hover:bg-slate-900">
        {t(locale, "menu")}
      </summary>
      <div class="absolute right-0 mt-2 w-56 overflow-hidden rounded-2xl border border-slate-800 bg-slate-950 shadow-xl">
        <nav class="flex flex-col p-2" aria-label="Mobile">
          {
            nav.map((item) => (
              <a
                class:list={[
                  "rounded-xl px-3 py-2 text-sm font-medium",
                  isActive(item.href)
                    ? "bg-slate-900 text-white"
                    : "text-slate-300 hover:bg-slate-900/60 hover:text-white",
                ]}
                href={item.href}
              >
                {item.label}
              </a>
            ))
          }
          <div class="my-2 h-px bg-slate-800/80" />
          <a
            class="rounded-xl px-3 py-2 text-sm font-medium text-slate-300 hover:bg-slate-900/60 hover:text-white"
            href={site.links.github}
            target="_blank"
            rel="noreferrer"
          >
            {t(locale, "github")}
          </a>
          {
            site.links.linkedin ? (
              <a
                class="rounded-xl px-3 py-2 text-sm font-medium text-slate-300 hover:bg-slate-900/60 hover:text-white"
                href={site.links.linkedin}
                target="_blank"
                rel="noreferrer"
              >
                {t(locale, "linkedin")}
              </a>
            ) : null
          }
          <a
            class="rounded-xl px-3 py-2 text-sm font-medium text-slate-300 hover:bg-slate-900/60 hover:text-white"
            href={toggleHref}
            lang={targetLocale}
          >
            {t(locale, "language")}:{" "}
            {targetLocale === "es" ? t(locale, "language_es") : t(locale, "language_en")}
          </a>
        </nav>
      </div>
    </details>
  </Container>
</header>
