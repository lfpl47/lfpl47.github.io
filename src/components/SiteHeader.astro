---
import Container from "./Container.astro";
import { site } from "../config/site";
import { getLocaleFromPathname, otherLocale, withLocale } from "../i18n/routing";
import { t } from "../i18n/ui";

const pathname = Astro.url.pathname;
const locale = getLocaleFromPathname(pathname);
const targetLocale = otherLocale(locale);
const toggleHref = withLocale(pathname, targetLocale);

const homeHref = withLocale("/", locale);
const nav = [
  { href: homeHref, label: t(locale, "home") },
  { href: withLocale("/experience/", locale), label: t(locale, "experience") },
  { href: withLocale("/projects/", locale), label: t(locale, "projects") },
  { href: withLocale("/training/", locale), label: t(locale, "training") },
  { href: withLocale("/cv/", locale), label: t(locale, "cv") },
];

function isActive(href: string) {
  if (href === homeHref) return pathname === homeHref;
  return pathname.startsWith(href);
}
---

<header class="sticky top-0 z-50 border-b border-slate-800/60 bg-slate-950/70 backdrop-blur">
  <Container class="flex h-16 items-center justify-between gap-4">
    <a class="flex items-center gap-2 font-semibold tracking-tight text-slate-100 hover:text-white" href={homeHref}>
      <img
        src={site.avatar.src}
        alt={site.avatar.alt[locale]}
        width="32"
        height="32"
        loading="eager"
        decoding="async"
        class="h-8 w-8 rounded-full border border-slate-800 object-cover"
      />
      <span>{site.handle}</span>
    </a>

    <nav class="hidden items-center gap-1 sm:flex" aria-label="Primary">
      {
        nav.map((item) => (
          <a
            class:list={[
              "rounded-full px-3 py-1.5 text-sm font-medium transition",
              isActive(item.href)
                ? "bg-slate-900 text-white"
                : "text-slate-300 hover:bg-slate-900/60 hover:text-white",
            ]}
            href={item.href}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="hidden items-center gap-2 sm:flex">
      <a
        class="inline-flex items-center gap-2 rounded-full border border-slate-800 bg-slate-900/40 px-3 py-1.5 text-sm font-semibold text-slate-100 hover:bg-slate-900"
        href={site.links.github}
        target="_blank"
        rel="noreferrer"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="h-4 w-4"
          aria-hidden="true"
        >
          <path d="M9 19c-5 1.5-5-2.5-7-3" />
          <path d="M16 22v-3.87a3.37 3.37 0 0 0-.94-2.61" />
          <path d="M9 22v-4.5a3.5 3.5 0 0 1 1-2.5c-3.14-.35-6.44-1.54-6.44-7A5.44 5.44 0 0 1 5 4.77 5.07 5.07 0 0 1 5.09 1S6.27.65 9 2.48a13.38 13.38 0 0 1 7 0C18.73.65 19.91 1 19.91 1A5.07 5.07 0 0 1 20 4.77a5.44 5.44 0 0 1 1.5 3.78c0 5.42-3.3 6.61-6.44 7A3.37 3.37 0 0 1 16 18.13V22" />
        </svg>
        {t(locale, "github")}
      </a>
      {
        site.links.linkedin ? (
          <a
            class="inline-flex items-center gap-2 rounded-full border border-slate-800 bg-slate-900/40 px-3 py-1.5 text-sm font-semibold text-slate-100 hover:bg-slate-900"
            href={site.links.linkedin}
            target="_blank"
            rel="noreferrer"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-4 w-4"
              aria-hidden="true"
            >
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
              <rect x="2" y="9" width="4" height="12" />
              <circle cx="4" cy="4" r="2" />
            </svg>
            {t(locale, "linkedin")}
          </a>
        ) : null
      }
      <a
        class="inline-flex items-center gap-2 rounded-full border border-slate-800 bg-slate-900/40 px-3 py-1.5 text-sm font-semibold text-slate-100 hover:bg-slate-900"
        href={toggleHref}
        aria-label={`${t(locale, "language")}: ${targetLocale === "es" ? t(locale, "language_es") : t(locale, "language_en")}`}
        lang={targetLocale}
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="h-4 w-4"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="10" />
          <path d="M2 12h20" />
          <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10Z" />
        </svg>
        {targetLocale.toUpperCase()}
      </a>
    </div>

    <details class="relative sm:hidden">
      <summary class="list-none rounded-full border border-slate-800 bg-slate-900/40 px-3 py-1.5 text-sm font-semibold text-slate-100 hover:bg-slate-900">
        {t(locale, "menu")}
      </summary>
      <div class="absolute right-0 mt-2 w-56 overflow-hidden rounded-2xl border border-slate-800 bg-slate-950 shadow-xl">
        <nav class="flex flex-col p-2" aria-label="Mobile">
          {
            nav.map((item) => (
              <a
                class:list={[
                  "rounded-xl px-3 py-2 text-sm font-medium",
                  isActive(item.href)
                    ? "bg-slate-900 text-white"
                    : "text-slate-300 hover:bg-slate-900/60 hover:text-white",
                ]}
                href={item.href}
              >
                {item.label}
              </a>
            ))
          }
          <div class="my-2 h-px bg-slate-800/80" />
          <a
            class="rounded-xl px-3 py-2 text-sm font-medium text-slate-300 hover:bg-slate-900/60 hover:text-white"
            href={site.links.github}
            target="_blank"
            rel="noreferrer"
          >
            <span class="inline-flex items-center gap-2">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="h-4 w-4"
                aria-hidden="true"
              >
                <path d="M9 19c-5 1.5-5-2.5-7-3" />
                <path d="M16 22v-3.87a3.37 3.37 0 0 0-.94-2.61" />
                <path d="M9 22v-4.5a3.5 3.5 0 0 1 1-2.5c-3.14-.35-6.44-1.54-6.44-7A5.44 5.44 0 0 1 5 4.77 5.07 5.07 0 0 1 5.09 1S6.27.65 9 2.48a13.38 13.38 0 0 1 7 0C18.73.65 19.91 1 19.91 1A5.07 5.07 0 0 1 20 4.77a5.44 5.44 0 0 1 1.5 3.78c0 5.42-3.3 6.61-6.44 7A3.37 3.37 0 0 1 16 18.13V22" />
              </svg>
              {t(locale, "github")}
            </span>
          </a>
          {
            site.links.linkedin ? (
              <a
                class="rounded-xl px-3 py-2 text-sm font-medium text-slate-300 hover:bg-slate-900/60 hover:text-white"
                href={site.links.linkedin}
                target="_blank"
                rel="noreferrer"
              >
                <span class="inline-flex items-center gap-2">
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="h-4 w-4"
                    aria-hidden="true"
                  >
                    <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                    <rect x="2" y="9" width="4" height="12" />
                    <circle cx="4" cy="4" r="2" />
                  </svg>
                  {t(locale, "linkedin")}
                </span>
              </a>
            ) : null
          }
          <a
            class="rounded-xl px-3 py-2 text-sm font-medium text-slate-300 hover:bg-slate-900/60 hover:text-white"
            href={toggleHref}
            lang={targetLocale}
          >
            <span class="inline-flex items-center gap-2">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="h-4 w-4"
                aria-hidden="true"
              >
                <circle cx="12" cy="12" r="10" />
                <path d="M2 12h20" />
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10Z" />
              </svg>
              {t(locale, "language")}:{" "}
              {targetLocale === "es" ? t(locale, "language_es") : t(locale, "language_en")}
            </span>
          </a>
        </nav>
      </div>
    </details>
  </Container>
</header>
