---
import Chip from "./Chip.astro";
import { getLocaleFromPathname } from "../i18n/routing";
import { t } from "../i18n/ui";

type Props = {
  href: string;
  company: string;
  role: string;
  dateRange: string;
  location?: string;
  highlights: string[];
  tags: string[];
};

const { href, company, role, dateRange, location, highlights, tags } = Astro.props;
const visibleTags = tags.slice(0, 8);
const moreCount = Math.max(0, tags.length - visibleTags.length);
const locale = getLocaleFromPathname(Astro.url.pathname);
---

<a
  class="group block rounded-3xl border border-slate-800 bg-slate-950/30 p-6 shadow-sm transition hover:border-slate-700 hover:bg-slate-900/30"
  href={href}
>
  <div class="flex flex-wrap items-baseline justify-between gap-3">
    <div>
      <h3 class="text-lg font-semibold text-slate-50">
        <span class="text-slate-300">{company}</span> · {role}
      </h3>
      <p class="mt-1 text-sm text-slate-400">
        {dateRange}{location ? ` · ${location}` : ""}
      </p>
    </div>
    <span class="text-sm font-semibold text-sky-300 opacity-0 transition group-hover:opacity-100">
      {t(locale, "view")} →
    </span>
  </div>

  <ul class="mt-4 list-disc space-y-1 pl-5 text-sm text-slate-300">
    {highlights.slice(0, 4).map((item) => <li>{item}</li>)}
  </ul>

  {tags.length ? (
    <div class="mt-5 flex flex-wrap gap-2">
      {visibleTags.map((t) => (
        <Chip label={t} />
      ))}
      {moreCount ? <Chip label={`+${moreCount}`} title={t(locale, "more")} /> : null}
    </div>
  ) : null}
</a>
